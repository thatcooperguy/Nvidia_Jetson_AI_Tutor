# EdgeTutor AI — Configuration
# Copy this file to .env and customize as needed.
# All settings have sensible defaults; the app will work without any changes.

# ─── Server ───────────────────────────────────────────────────────────────────
EDGETUTOR_HOST=0.0.0.0
EDGETUTOR_PORT=7860

# ─── LLM ──────────────────────────────────────────────────────────────────────
# Path to GGUF model file (relative to repo root or absolute)
LLM_MODEL_PATH=models/default.gguf
# Number of GPU layers to offload (0 = CPU-only, -1 = all layers on GPU)
LLM_N_GPU_LAYERS=20
# Context window size (tokens)
LLM_CONTEXT_SIZE=2048
# Max tokens per response
LLM_MAX_TOKENS=512
# Temperature (0.0–1.0)
LLM_TEMPERATURE=0.7

# ─── Speech-to-Text ──────────────────────────────────────────────────────────
# Model size: tiny, base, small, medium (small recommended for Jetson)
STT_MODEL_SIZE=small
# Device: cuda or cpu
STT_DEVICE=cuda
# Compute type: float16, int8_float16, int8 (for Jetson use float16 or int8)
STT_COMPUTE_TYPE=float16
# Language (empty = auto-detect)
STT_LANGUAGE=en
# Set to false to disable STT and use text-only mode
STT_ENABLED=true

# ─── Text-to-Speech ──────────────────────────────────────────────────────────
# Path to Piper voice model (.onnx) — relative to repo root or absolute
TTS_VOICE_MODEL=voices/en_US-lessac-medium.onnx
# Set to false to disable TTS (text-only output)
TTS_ENABLED=true
# Speech rate multiplier (1.0 = normal)
TTS_RATE=1.0

# ─── Vision / OCR ────────────────────────────────────────────────────────────
# OCR engine: tesseract
OCR_ENGINE=tesseract
# Tesseract language(s), e.g. eng, eng+spa
OCR_LANGUAGE=eng
# Enable camera support (false = image upload only)
CAMERA_ENABLED=true

# ─── RAG ──────────────────────────────────────────────────────────────────────
# Path to curriculum content folder
RAG_CONTENT_DIR=content/
# Path to FAISS index
RAG_INDEX_DIR=edgetutor/core/faiss_index/
# Embedding model name (will be downloaded during setup)
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
# Number of retrieved chunks
RAG_TOP_K=3
# Chunk size (characters)
RAG_CHUNK_SIZE=500

# ─── Safety ───────────────────────────────────────────────────────────────────
# Enable kid-safe guardrails (always on by default)
SAFETY_ENABLED=true

# ─── Logging ──────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
# Log file path
LOG_FILE=logs/edgetutor.log
